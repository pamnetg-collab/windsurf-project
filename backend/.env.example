# ── Server ──────────────────────────────────────────────
PORT=4000
NODE_ENV=development
PUBLIC_API_URL=http://localhost:4000
# Comma-separated list of allowed CORS origins in production (empty = allow all)
CORS_ORIGINS=
# Process role for horizontal scaling: all (default) | api | worker
# all    = API + bot + cron (single instance)
# api    = API only (run many behind load balancer)
# worker = bot + cron only (run exactly ONE instance)
PROCESS_ROLE=all

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://vpn:vpn@localhost:5432/vpn_saas?schema=public

# ── Auth ────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── Telegram ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:replace_with_real_bot_token
TELEGRAM_BOT_USERNAME=your_bot_username
# Payment provider token from @BotFather (Telegram Payments). Leave empty to use Telegram Stars.
TELEGRAM_PAYMENT_PROVIDER_TOKEN=
# Public URL of the Telegram Mini App / admin
MINI_APP_URL=http://localhost:5173

# ── Payments ────────────────────────────────────────────
# Shared secret for POST /payment/webhook (external providers only).
# Leave EMPTY to disable the webhook entirely (Telegram Stars don't need it).
PAYMENT_WEBHOOK_SECRET=

# ── Business rules ──────────────────────────────────────
TRIAL_DAYS=14
REFERRAL_REWARD_DAYS=7
REFERRAL_DAILY_LIMIT=10
# Max simultaneous devices per VPN key (3x-ui limitIp). 0 = unlimited.
DEVICE_LIMIT=1
# Days after subscription expiry before VPN key is deleted (grace period).
# During grace the key is disabled (not deleted) so renewals restore it.
GRACE_DAYS=2

# ── Admin bootstrap (created on seed) ───────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
